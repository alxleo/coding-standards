#!/usr/bin/env python3
"""Verify every linter hook in .pre-commit-config.yaml uses --config.

Catches the exact bug where a pre-commit hook silently falls back to
default config because the --config flag was omitted. Checks that
every hook for a tool with a config in lint-configs-626465/ has an
explicit --config, -c, or --config-file argument.

Tools that don't use config files (check-yaml, detect-private-key, etc)
are excluded via SKIP_HOOKS.
"""

import sys
from pathlib import Path

import yaml

# Hooks that don't need --config (no config file, or config is inline)
SKIP_HOOKS = {
    # pre-commit-hooks (stateless checks)
    "check-yaml",
    "check-json",
    "check-toml",
    "check-merge-conflict",
    "check-added-large-files",
    "detect-private-key",
    "end-of-file-fixer",
    "trailing-whitespace",
    "check-case-conflict",
    "check-executables-have-shebangs",
    "check-shebang-scripts-are-executable",
    # local hooks (custom scripts, not configurable linters)
    "forbid-cruft-files",
    "block-secret-files",
    "verify-sops-encryption",
    "shell-hygiene",
    "just-fmt-check",
    "caddy-fmt-check",
    "pytest",
    "catalog-drift",
    # External tools without configs in lint-configs-626465/
    "actionlint",
    "zizmor",
}

CONFIG_FLAGS = {"--config", "-c", "--config-file"}


def check(config_path: Path) -> list[str]:
    data = yaml.safe_load(config_path.read_text())
    errors = []

    for repo in data.get("repos", []):
        for hook in repo.get("hooks", []):
            hook_id = hook.get("id", "")
            if hook_id in SKIP_HOOKS:
                continue

            args = hook.get("args", [])
            entry = hook.get("entry", "")

            # nosemgrep: python-silent-fallback-or — boolean logic, not fallback
            has_config = any(flag in arg for arg in args for flag in CONFIG_FLAGS) or any(
                flag in entry for flag in CONFIG_FLAGS
            )

            if not has_config:
                errors.append(f"Hook '{hook_id}' has no --config flag. Add --config lint-configs-626465/... to args.")

    return errors


if __name__ == "__main__":
    config = Path("lint-configs-626465/.pre-commit-config.yaml")
    if not config.exists():
        print(f"Not found: {config}")
        sys.exit(1)

    errors = check(config)
    if errors:
        print("Missing --config flags in pre-commit hooks:")
        for e in errors:
            print(f"  ✗ {e}")
        sys.exit(1)

    print("All linter hooks have explicit --config flags.")
