#!/usr/bin/env bash
# Shell hygiene checks — combined hook for the "shell" linter group.
#
# Checks:
#   1. Forbid bare python/python3 — use uv run instead
#   2. mktemp without trap EXIT cleanup — leaked temp files on error paths
#   3. Unpinned npx versions — breaks reproducibility
#
# No set -e: grep exit codes are used as signals.
set -uo pipefail

is_shell() {
    case "$1" in
        *.sh|*.bash) return 0 ;;
    esac
    head -1 "$1" 2>/dev/null | grep -qE '^#!.*\b(ba)?sh\b'
}

rc=0
for f in "$@"; do
    # Checks 1 & 2 only apply to shell scripts (not YAML)
    if is_shell "$f"; then
        # 1. Forbid bare python/python3 (uv run is required)
        matches=$(grep -nE "(^|[[:space:]])python3?[[:space:]]" "$f" | grep -v "uv run" || true)
        if [ -n "$matches" ]; then
            echo "$f: bare python/python3 — use 'uv run python3' instead:"
            echo "$matches" | sed 's/^/  /'
            rc=1
        fi

        # 2. mktemp without trap cleanup
        if grep -q "mktemp" "$f" && ! grep -q "trap" "$f"; then
            echo "$f: mktemp without trap EXIT cleanup — temp files leak on error"
            rc=1
        fi
    fi

    # 3. Unpinned npx versions (shell scripts only — skip YAML rule definitions)
    case "$f" in
        *.yml|*.yaml) continue ;;
    esac
    matches=$(grep -nE "npx [a-z]" "$f" | grep -vE "npx (--yes|--no|-)|@[0-9]|#.*npx|^[^:]*:.*name:" || true)
    if [ -n "$matches" ]; then
        echo "$f: unpinned npx — pin versions (e.g. npx tool@1.2.3):"
        echo "$matches" | sed 's/^/  /'
        rc=1
    fi
done
exit "$rc"
