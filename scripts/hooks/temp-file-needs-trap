#!/usr/bin/env bash
# Shell scripts that create temp files must clean up with trap EXIT.
# mktemp without trap → leaked temp files on error paths.
set -uo pipefail

for f in "$@"; do
    if grep -q "mktemp" "$f" && ! grep -q "trap" "$f"; then
        echo "ERROR: $f uses mktemp without trap EXIT cleanup"
        exit 1
    fi
done
