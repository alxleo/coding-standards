# coding-standards consumer justfile
# Drop this into your repo root for ergonomic lint commands.
#
# Usage:
#   just lint              # full suite
#   just lint ruff         # single linter
#   just fix               # auto-fix all
#   just standards         # repo-standards only
#   just catalog           # show what's checked

image := "ghcr.io/alxleo/coding-standards:latest"
workspace := justfile_directory()

# Run full lint suite
[doc('Run all linters')]
lint *LINTER:
    #!/usr/bin/env bash
    set -euo pipefail
    args=(-v "{{workspace}}:/tmp/lint" -e DEFAULT_WORKSPACE=/tmp/lint)
    if [ -n "{{LINTER}}" ]; then
        args+=(-e "ENABLE_LINTERS={{uppercase(LINTER)}}")
    fi
    docker run --rm "${args[@]}" {{image}}

# Auto-fix formatting issues
[doc('Auto-fix all fixable issues')]
fix:
    docker run --rm \
        -v "{{workspace}}:/tmp/lint" \
        -e DEFAULT_WORKSPACE=/tmp/lint \
        -e APPLY_FIXES=all \
        {{image}}

# Run repo-standards checks only
[doc('Check repo setup against standards')]
standards:
    #!/usr/bin/env bash
    set -euo pipefail
    docker run --rm --entrypoint="" \
        -v "{{workspace}}:/tmp/lint" \
        {{image}} \
        sh -c "cd /tmp/lint && python3 /opt/coding-standards/scripts/generate-repo-manifest.py && conftest test repo-manifest.json --all-namespaces --no-color -p /opt/coding-standards/policies/repo-standards/ && rm -f repo-manifest.json"

# Show what the image checks
[doc('Show full catalog of checks')]
catalog:
    docker run --rm --entrypoint="" {{image}} cat /opt/coding-standards/docs/catalog.md

# Pre-commit: run before committing (catches what CI would catch)
[doc('Run pre-commit checks locally')]
check:
    uvx pre-commit run --all-files
