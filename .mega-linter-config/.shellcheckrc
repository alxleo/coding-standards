# ShellCheck baseline — synced to all repos.
# Per-repo overrides: add a local .shellcheckrc with `disable=SCXXXX`.

# Catch exit codes silently swallowed in command substitutions.
# e.g., rm -r "$(get_dir)/home" — if get_dir fails, you rm /home.
enable=check-extra-masked-returns

# Flag `which` — use `command -v` instead (POSIX, reliable).
enable=deprecate-which

# Functions in || conditions silently lose set -e, swallowing failures.
enable=check-set-e-suppressed

# case statements without *) default — silent no-ops are worse than loud failures.
enable=add-default-case

# Require [[ ]] instead of [ ] in bash scripts (prevents word splitting bugs).
# Only fires on #!/bin/bash scripts — #!/bin/sh scripts are unaffected.
enable=require-double-brackets

# Follow source directives so sourced files get checked too.
external-sources=true
