# LEGACY — synced to repos via github-standards file-sync.
# New repos use templates/justfile.consumer (fetch-and-run model).
# Dev tasks (test, test-hooks, etc.) live in the root justfile.

set unstable := true

[doc('Install pre-commit + custom git hooks')]
[group('setup')]
setup:
    #!/usr/bin/env bash
    if [ -x "scripts/setup-hooks.sh" ]; then
        bash scripts/setup-hooks.sh
    else
        echo "Installing pre-commit hooks..."
        uvx pre-commit install
    fi

[doc('Check prerequisites for local development')]
[group('setup')]
doctor:
    scripts/doctor.sh bats

[doc('Run pre-commit on all files')]
[group('lint')]
lint:
    uvx pre-commit run --all-files

[doc('Remove cruft files and stale test branches')]
[group('maintenance')]
clean:
    find . -not -path "./.git/*" -not -path "./tests/fixtures/*" \( -name "*.del" -o -name "*.bak" -o -name "*.old" -o -name "*.tmp" -o -name "*.orig" \) -delete -print
    -git branch -D test/hook-validation 2>/dev/null
