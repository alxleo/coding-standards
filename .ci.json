{
  "test_commands": [
    "trivy --version",
    "pmd --version",
    "caddy version",
    "just --version",
    "conftest --version",
    "npx commitlint --version || true",
    "pyright --version",
    "zizmor --version",
    "knip --version",
    "dclint --version",
    "tsc --version",
    "depcruise --version",
    "license-checker --version || true",
    "conftest verify -p /opt/coding-standards/policies/repo-standards/",
    "conftest verify -p /opt/coding-standards/policies/compose/",
    "semgrep scan --config /opt/coding-standards/semgrep-rules/ --validate",
    "cd /tmp && python3 /opt/coding-standards/scripts/generate-repo-manifest.py && test -f repo-manifest.json"
  ]
}
